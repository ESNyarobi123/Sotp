APP_NAME="SKY Omada WiFi"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Production: set SESSION_SECURE_COOKIE=true when using HTTPS; optional SESSION_SAME_SITE=strict
# SESSION_SECURE_COOKIE=true
# SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ─────────────────────────────────────────────────────────────────────────────
# Public URL (ngrok / Cloudflare Tunnel / LocalXpose)
# ─────────────────────────────────────────────────────────────────────────────
# Used when the app must generate absolute URLs (captive portal, webhooks).
# Leave empty to rely on APP_URL and request headers where supported.
PUBLIC_URL=

# ─────────────────────────────────────────────────────────────────────────────
# Multi-tenant model (one Omada controller, many customer workspaces)
# ─────────────────────────────────────────────────────────────────────────────
# - Omada Open API credentials below are PLATFORM-level: one Software Controller
#   (omadacId + client credentials). Each customer "brand" is a workspace with its
#   own Omada site id stored in the database (workspaces.omada_site_id), usually
#   created in the background after registration.
# - OMADA_SITE_ID is optional. If set, it is the default Omada site when a workspace
#   has no site id yet, and it seeds the demo workspace in DatabaseSeeder.
# - Legacy controller UI fields (username/password) live in Admin → Omada Integration
#   (omada_settings) unless you also set the OMADA_* vars here — OmadaService prefers
#   .env then falls back to the database row.

# ─── Omada Controller (optional .env mirror of Admin → Omada Integration) ───
OMADA_CONTROLLER_URL=https://your-omada-controller.com:8043
OMADA_USERNAME=admin
OMADA_PASSWORD=
OMADA_HOTSPOT_OPERATOR=
OMADA_HOTSPOT_PASSWORD=

# ─── Omada Open API (Client Credentials — required for API + provisioning) ───
OMADA_CONTROLLER_ID=
OMADA_CLIENT_ID=
OMADA_CLIENT_SECRET=
# Optional default site (see "Multi-tenant model" above)
OMADA_SITE_ID=
OMADA_VERIFY_SSL=false

# ─── ClickPesa (per-workspace in production) ────────────────────────────────
# Live credentials are stored per workspace in Admin → Payment Gateways (database).
# Keep these empty unless you use them for local scripts or a future env fallback.
CLICKPESA_CLIENT_ID=
CLICKPESA_API_KEY=
CLICKPESA_CHECKSUM_KEY=
CLICKPESA_WEBHOOK_URL="${APP_URL}/api/clickpesa/webhook"

# ─── Optional: Horizon / Redis queue ─────────────────────────────────────────
# QUEUE_CONNECTION=redis

# ─── Optional: Pusher-compatible realtime (e.g. Soketi) ──────────────────────
# BROADCAST_CONNECTION=pusher
# PUSHER_APP_ID=
# PUSHER_APP_KEY=
# PUSHER_APP_SECRET=
# PUSHER_HOST=127.0.0.1
# PUSHER_PORT=6001
# PUSHER_SCHEME=http
# VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
# VITE_PUSHER_HOST="${PUSHER_HOST}"
# VITE_PUSHER_PORT="${PUSHER_PORT}"
# VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
# VITE_PUSHER_APP_CLUSTER=mt1
